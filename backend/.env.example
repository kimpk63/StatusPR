# Backend configuration example
PORT=3001
API_KEY=your_api_key_here
DATABASE_PATH=./database/status.db

# Google Drive API credentials (see README for how to get these)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/drive/callback
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_OUTPUT_FOLDER_ID=
GOOGLE_DRIVE_INPUT_FOLDER_ID=

# optional comma-separated list of allowed CORS origins for frontend
# e.g. https://statuspr-dashboard.netlify.app,https://example.com
CORS_ORIGINS=

# authentication / JWT
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d
